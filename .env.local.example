# Copy this file to `.env.local` and fill in your value.
#
# The @wix/astro integration reads WIX_CLIENT_ID (via astro:env) and sets up
# the Wix SDK auth context on both server and client automatically.
# Find it in the Wix dashboard: Settings → Headless Settings → OAuth apps.
WIX_CLIENT_ID=your-oauth-client-id-here
