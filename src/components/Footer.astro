---
import { SITE, NAV } from '../lib/site';
import Marquee from './Marquee.astro';

const bandItems = [SITE.social.instagramHandle, SITE.social.secondaryHandle, 'San Sebastián', 'Driftwood Fire'];
---

<Marquee variant="band" items={bandItems} speed={26} />

<footer class="site-footer">
  <div class="mx-auto grid max-w-6xl gap-10 px-5 py-16 sm:grid-cols-2 lg:grid-cols-4">
    <div class="lg:col-span-1">
      <span class="brand-name text-[var(--color-on-dark)]">{SITE.name}</span>
      <p class="mt-3 max-w-xs text-sm text-[color-mix(in_oklab,var(--color-on-dark)_64%,transparent)]">
        {SITE.tagline}. Driftwood-fired, above the harbor in {SITE.locality} since {SITE.established}.
      </p>
    </div>

    <div>
      <h2 class="footer-head">Visit</h2>
      <address class="not-italic text-sm text-[color-mix(in_oklab,var(--color-on-dark)_72%,transparent)]">
        {SITE.street}<br />
        {SITE.locality}, {SITE.region}<br />
        <a href={`tel:${SITE.phoneHref}`} class="footer-link mt-2 inline-block">{SITE.phone}</a>
      </address>
    </div>

    <div>
      <h2 class="footer-head">Hours</h2>
      <ul class="space-y-1 text-sm text-[color-mix(in_oklab,var(--color-on-dark)_72%,transparent)]">
        {
          SITE.hours.map((h) => (
            <li>
              <span class="text-[var(--color-on-dark)]">{h.service}</span> · {h.days} · {h.time}
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2 class="footer-head">More</h2>
      <ul class="space-y-1 text-sm">
        {NAV.map((i) => (
          <li><a href={i.href} class="footer-link">{i.label}</a></li>
        ))}
        <li><a href="/reservations" class="footer-link">Book a Table</a></li>
      </ul>
      <div class="mt-4 flex gap-4 text-sm">
        <a href={SITE.social.instagram} class="footer-link" rel="noreferrer" target="_blank">
          {SITE.social.instagramHandle}
        </a>
      </div>
    </div>
  </div>
  <div class="footer-wordmark-wrap" aria-hidden="true">
    <span class="footer-wordmark">Salt Meridian</span>
  </div>

  <div class="border-t border-[color-mix(in_oklab,var(--color-on-dark)_14%,transparent)]">
    <div class="mx-auto flex max-w-6xl flex-col gap-2 px-5 py-6 text-xs text-[color-mix(in_oklab,var(--color-on-dark)_52%,transparent)] sm:flex-row sm:items-center sm:justify-between">
      <span>© {SITE.established}–present {SITE.name} · {SITE.locality}</span>
      <span>Coastal Basque cooking, fired over driftwood</span>
    </div>
  </div>
</footer>
